# This file lists the settings a deployment may provide. It contains no real
# credentials and is safe to keep as a reference; copy values into Render rather
# than renaming this file to .env and committing secrets.
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com
DJANGO_TRUST_PROXY_SSL_HEADER=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SERVE_MEDIA=True
DJANGO_MEDIA_ROOT=/opt/render/project/src/media
DATABASE_URL=
